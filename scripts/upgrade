#!/bin/bash

echo "ℹ️  Dotfiles"
if [[ -d ~/.dotfiles && -d ~/.dotfiles/.git ]]; then
  (cd ~/.dotfiles && git pull)
else
  echo "  Warning: ~/.dotfiles not a git repo, skipping"
fi

echo "ℹ️  Brew"
brew update
brew upgrade --yes
brew upgrade --cask --greedy --yes
brew cleanup -s

echo "ℹ️  Brew diagnostic"
brew doctor
brew missing

echo "ℹ️  Mas upgrade"
mas outdated
mas upgrade

echo "ℹ️  npm global packages upgrade"
if command -v npm &> /dev/null; then
  npm update -g
else
  echo "  Warning: npm not found, skipping npm global package updates"
fi

echo "ℹ️  Skills update"
if command -v skills &> /dev/null; then
  skills update -g
else
  echo "  Warning: skills not found, skipping skills updates"
fi

echo "ℹ️  Claude Code CLI update"
if command -v claude &> /dev/null; then
  claude update
else
  echo "  Warning: claude not found, skipping Claude Code CLI update"
fi

echo "ℹ️  Claude plugins update"
if command -v claude &> /dev/null && command -v jq &> /dev/null; then
  claude plugin list --json | jq -r '.[].id' | while read -r plugin; do
    [[ -n "$plugin" ]] && claude plugin update "$plugin"
  done
else
  echo "  Warning: claude or jq not found, skipping Claude plugin updates"
fi

echo "ℹ️  NeoVim plugins"
if command -v nvim &> /dev/null; then
  nvim --headless '+Lazy! sync' +qa
  if [[ -n "$(git -C ~/.dotfiles status --porcelain -- nvim/lazy-lock.json)" ]]; then
    git -C ~/.dotfiles commit -m "chore(nvim): update plugins" -- nvim/lazy-lock.json &&
      git -C ~/.dotfiles push
  fi
else
  echo "  Warning: nvim not found, skipping NeoVim plugin updates"
fi
