#!/bin/bash

echo "ℹ️  Dotfiles"
if [[ -d ~/.dotfiles && -d ~/.dotfiles/.git ]]; then
  (cd ~/.dotfiles && git pull)
else
  echo "  Warning: ~/.dotfiles not a git repo, skipping"
fi

echo "ℹ️  Brew"
brew update
brew upgrade
brew upgrade --cask --greedy
brew cleanup -s

echo "ℹ️  Brew diagnostic"
brew doctor
brew missing

echo "ℹ️  Mas upgrade"
mas outdated
mas upgrade

echo "ℹ️  npm global packages upgrade"
if command -v npm &> /dev/null; then
  npm update -g
else
  echo "  Warning: npm not found, skipping npm global package updates"
fi

echo "ℹ️  Skills update"
if command -v skills &> /dev/null; then
  skills update -g
else
  echo "  Warning: skills not found, skipping skills updates"
fi

echo "ℹ️  NeoVim plugins"
if command -v nvim &> /dev/null; then
  nvim --headless '+Lazy! sync' +qa
else
  echo "  Warning: nvim not found, skipping NeoVim plugin updates"
fi
